<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <PackageId>ResolutionBuddy</PackageId>
    <Version>5.0.1</Version>
    <Title>ResolutionBuddy</Title>
    <Authors>dmanning23</Authors>
    <description>Easily manage the window resolution of an MonoGame project</description>
    <PackageProjectUrl>https://github.com/dmanning23/FontBuddy</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/dmanning23/FontBuddy</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>monogame</PackageTags>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.*">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="RandomExtensions.dmanning23" Version="5.*" />
    <PackageReference Include="Vector2Extensions" Version="5.*" />
    <PackageReference Include="MatrixExtensions" Version="5.*" />
  </ItemGroup>
</Project>